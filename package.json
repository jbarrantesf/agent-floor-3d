{
  "name": "nexai-agent-floor-3d",
  "version": "0.2.0",
  "description": "NexAI Agent Floor 3D / Mission Control Alpha — Visual orchestration for Hermes + ORBIT with bilateral Supabase communication",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "tsx server.ts",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "setup:supabase": "bash scripts/setup-supabase.sh",
    "test": "tsx scripts/test-sprint-2-5.ts",
    "test:watch": "tsx --watch scripts/test-sprint-2-5.ts"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.16.0",
    "@supabase/supabase-js": "^2.39.6",
    "@types/node-fetch": "^2.6.13",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "three": "^0.160.0",
    "three-stdlib": "^2.36.1",
    "uuid": "^14.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/ws": "^8.5.8",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.1",
    "eslint": "^8.52.0",
    "node-fetch": "^2.7.0",
    "postcss": "^8.4.31",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.1.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  }
}
